# ─────────────────────────────────────────────
# Agent Brain Chip — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────

# ── Discord Bot Tokens ────────────────────────
# Create bots at https://discord.com/developers/applications
# Each agent needs its own bot token.
AGENT1_TOKEN=
AGENT2_TOKEN=
AGENT3_TOKEN=

# ── Agent Names & Roles ───────────────────────
# These become the agent's identity (shown in responses).
AGENT1_NAME=Agent 1
AGENT1_ROLE=Strategic Advisor
AGENT1_SLASH=/agent1

AGENT2_NAME=Agent 2
AGENT2_ROLE=Creative Director
AGENT2_SLASH=/agent2

AGENT3_NAME=Agent 3
AGENT3_ROLE=Technical Lead
AGENT3_SLASH=/agent3

# ── Chip Directories ──────────────────────────
# Path to each agent's brain chip folder (SOUL/SKILL/MEMORY/BRIDGE).
# Defaults to ./chips/agentN if not set.
# AGENT1_CHIP_DIR=./chips/agent1
# AGENT2_CHIP_DIR=./chips/agent2
# AGENT3_CHIP_DIR=./chips/agent3

# ── Model Backend ─────────────────────────────
# Choose one backend per agent (or share across all agents).

# Option A — Anthropic SDK (recommended for production)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Option B — Claude CLI (uses existing Claude Pro subscription)
# No key needed. Requires `claude` CLI installed and logged in.
# CLAUDE_BIN=                  # default: ~/.local/bin/claude
# CLAUDE_BIN_DIR=              # optional: extra PATH directory

# Option C — Ollama (local, free)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=exaone3.5:2.4b  # recommended for Korean; llama3.2 for English

# ── Optional Context Board ────────────────────
# Path to a markdown file injected as real-time context into every response.
# Use this for a shared team status board, project notes, etc.
# CONTEXT_FILE=./context.md

# ── Shared Context ────────────────────────────
# Path for inter-agent conversation history (JSON).
# Defaults to ./shared_context.json
# SHARED_CONTEXT_PATH=./shared_context.json
