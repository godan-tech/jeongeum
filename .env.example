# ─────────────────────────────────────────────
# Agent Brain Chip — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────

# ── Discord Bot Tokens ────────────────────────
# Create bots at https://discord.com/developers/applications
# Each agent needs its own bot token.
AGENT1_TOKEN=
AGENT2_TOKEN=
AGENT3_TOKEN=

# ── Agent Names & Roles ───────────────────────
# These become the agent's identity (shown in responses).
AGENT1_NAME=Agent 1
AGENT1_ROLE=Strategic Advisor
AGENT1_SLASH=/agent1

AGENT2_NAME=Agent 2
AGENT2_ROLE=Creative Director
AGENT2_SLASH=/agent2

AGENT3_NAME=Agent 3
AGENT3_ROLE=Technical Lead
AGENT3_SLASH=/agent3

# ── Chip Directories ──────────────────────────
# Path to each agent's brain chip folder (SOUL/SKILL/MEMORY/BRIDGE).
# Defaults to ./chips/agentN if not set.
# AGENT1_CHIP_DIR=./chips/agent1
# AGENT2_CHIP_DIR=./chips/agent2
# AGENT3_CHIP_DIR=./chips/agent3

# ── Model Backend ─────────────────────────────
# Uncomment ONE block below and set MODEL_BACKEND accordingly.

# MODEL_BACKEND=anthropic-sdk   # Option A
# MODEL_BACKEND=gemini          # Option B (free tier)
# MODEL_BACKEND=ollama          # Option C (local)

# Option A — Anthropic SDK (recommended for production)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # or claude-haiku-4-5-20251001

# Option B — Gemini API (free tier, officially approved for bots)
# Get a free key at https://aistudio.google.com — no credit card required.
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash       # or gemini-1.5-pro for higher quality

# Option C — Ollama (local, free, no data leaves your machine)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3                 # or exaone3.5:2.4b for Korean

# ⚠️  Claude CLI is NOT recommended for bots — see docs/03-model-backends.md

# ── Optional Context Board ────────────────────
# Path to a markdown file injected as real-time context into every response.
# Use this for a shared team status board, project notes, etc.
# CONTEXT_FILE=./context.md

# ── Shared Context ────────────────────────────
# Path for inter-agent conversation history (JSON).
# Defaults to ./shared_context.json
# SHARED_CONTEXT_PATH=./shared_context.json
